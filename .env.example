# ── Default Network ────────────────────────────────────────────────────────────
# Set to "mainnet" to default new users to 0G Mainnet. Defaults to testnet.
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# ── WalletConnect ──────────────────────────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Legacy / Backward-Compat Vars (still read as testnet fallbacks) ────────────
# These are kept for compatibility with existing deployments.
# Prefer the NEXT_PUBLIC_TESTNET_* vars below for new setups.
NEXT_PUBLIC_ZERO_G_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_ZERO_G_CHAIN_ID=16602
NEXT_PUBLIC_ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_ZERO_G_STORAGE_EXPLORER=https://storagescan-galileo.0g.ai
NEXT_PUBLIC_ZERO_G_CHAIN_EXPLORER=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
NEXT_PUBLIC_CREDENTIAL_CONTRACT=0x_deployed_contract_address_here

# ── Testnet Contract Addresses (0G Galileo — Chain ID 16602) ──────────────────
# Deploy: npx hardhat run scripts/deploy-all.js --network 0g-testnet
NEXT_PUBLIC_TESTNET_SOULBOUND_ADDRESS=
NEXT_PUBLIC_TESTNET_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_TESTNET_INFT_ADDRESS=
NEXT_PUBLIC_TESTNET_HIRING_ADDRESS=
NEXT_PUBLIC_TESTNET_TOKEN_ADDRESS=
NEXT_PUBLIC_TESTNET_STAKING_ADDRESS=
NEXT_PUBLIC_TESTNET_GOVERNOR_ADDRESS=
NEXT_PUBLIC_TESTNET_REWARDS_DISTRIBUTOR=
NEXT_PUBLIC_TESTNET_TIMELOCK=
NEXT_PUBLIC_TESTNET_TREASURY=
NEXT_PUBLIC_TESTNET_CROSS_CHAIN_VERIFIER=
NEXT_PUBLIC_TESTNET_API_KEY_REGISTRY=
NEXT_PUBLIC_TESTNET_STORAGE_FLOW=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# ── Mainnet Contract Addresses (0G Mainnet — Chain ID 16661) ─────────────────
# Deploy: npx hardhat run scripts/deploy-all.js --network 0g-mainnet
# Leave blank until deployed — all mainnet features gracefully degrade.
NEXT_PUBLIC_MAINNET_SOULBOUND_ADDRESS=
NEXT_PUBLIC_MAINNET_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_MAINNET_INFT_ADDRESS=
NEXT_PUBLIC_MAINNET_HIRING_ADDRESS=
NEXT_PUBLIC_MAINNET_TOKEN_ADDRESS=
NEXT_PUBLIC_MAINNET_STAKING_ADDRESS=
NEXT_PUBLIC_MAINNET_GOVERNOR_ADDRESS=
NEXT_PUBLIC_MAINNET_REWARDS_DISTRIBUTOR=
NEXT_PUBLIC_MAINNET_TIMELOCK=
NEXT_PUBLIC_MAINNET_TREASURY=
NEXT_PUBLIC_MAINNET_CROSS_CHAIN_VERIFIER=
NEXT_PUBLIC_MAINNET_API_KEY_REGISTRY=
NEXT_PUBLIC_MAINNET_STORAGE_FLOW=

# ── 0G Compute — AI Inference (optional, enables real AI scoring) ─────────────
# Step 1: pnpm add @0glabs/0g-serving-broker -g
# Step 2: 0g-compute-cli setup-network && 0g-compute-cli login
# Step 3: 0g-compute-cli deposit --amount 1
# Step 4: 0g-compute-cli inference list-providers
# Step 5: 0g-compute-cli inference get-secret --provider <PROVIDER_ADDR>
# Step 6: Set these vars:
COMPUTE_SERVICE_URL=https://your-provider-url/v1/proxy
COMPUTE_API_KEY=app-sk-your_secret_key_here
COMPUTE_MODEL=qwen-2.5-7b-instruct

# ── Admin ──────────────────────────────────────────────────────────────────────
# Wallet address that can view admin stats (optional, defaults to all)
NEXT_PUBLIC_ADMIN_ADDRESS=0x_your_admin_wallet_address

# ── Phase 4 Contracts (legacy names — use TESTNET/MAINNET vars above for new setups) ──
NEXT_PUBLIC_INFT_CONTRACT=0x_inft_contract_address_here
NEXT_PUBLIC_MARKETPLACE_CONTRACT=0x_marketplace_contract_address_here
NEXT_PUBLIC_HIRING_ESCROW_CONTRACT=0x_hiring_escrow_address_here
NEXT_PUBLIC_TRUST_TOKEN_CONTRACT=0x_trust_token_address_here
NEXT_PUBLIC_STAKING_CONTRACT=0x_staking_address_here
NEXT_PUBLIC_REWARDS_DISTRIBUTOR_CONTRACT=0x_rewards_distributor_address_here
NEXT_PUBLIC_TRUST_GOVERNOR_CONTRACT=0x_trust_governor_address_here
NEXT_PUBLIC_TIMELOCK_CONTRACT=0x_timelock_address_here
NEXT_PUBLIC_TREASURY_CONTRACT=0x_treasury_address_here
NEXT_PUBLIC_CROSS_CHAIN_VERIFIER_CONTRACT=0x_cross_chain_verifier_address_here
NEXT_PUBLIC_API_KEY_REGISTRY_CONTRACT=0x_api_key_registry_address_here
