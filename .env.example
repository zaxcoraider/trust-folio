# 0G Network — Galileo Testnet
NEXT_PUBLIC_ZERO_G_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_ZERO_G_CHAIN_ID=16602
NEXT_PUBLIC_ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_ZERO_G_STORAGE_EXPLORER=https://storagescan-galileo.0g.ai
NEXT_PUBLIC_ZERO_G_CHAIN_EXPLORER=https://chainscan-galileo.0g.ai

# Storage contract (Galileo Testnet)
NEXT_PUBLIC_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# WalletConnect Project ID — get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# 0G Compute — AI Inference (optional, enables real AI scoring)
# Step 1: pnpm add @0glabs/0g-serving-broker -g
# Step 2: 0g-compute-cli setup-network && 0g-compute-cli login
# Step 3: 0g-compute-cli deposit --amount 1
# Step 4: 0g-compute-cli inference list-providers
# Step 5: 0g-compute-cli inference get-secret --provider <PROVIDER_ADDR>
# Step 6: Set these vars:
COMPUTE_SERVICE_URL=https://your-provider-url/v1/proxy
COMPUTE_API_KEY=app-sk-your_secret_key_here
COMPUTE_MODEL=qwen-2.5-7b-instruct

# Server-side wallet for compute (needs testnet 0G — get from https://faucet.0g.ai)
# Also used to upload proof JSONs to 0G Storage and mint soul-bound tokens
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Soul-Bound Credential Contract — deploy with:
#   npx hardhat run scripts/deploy.js --network 0g-testnet
# Then paste the printed address in both vars below:
NEXT_PUBLIC_CREDENTIAL_CONTRACT=0x_deployed_contract_address_here
CREDENTIAL_CONTRACT=0x_deployed_contract_address_here

# ── Phase 3: INFT Marketplace ──────────────────────────────────────────────────
# Deploy all Phase 3 contracts at once:
#   npx hardhat run scripts/deploy-all.js --network 0g-testnet
# Then paste the printed addresses below:

# TrustFolioINFT contract (ERC-7857 Intelligent NFT)
NEXT_PUBLIC_INFT_CONTRACT=0x_inft_contract_address_here
INFT_CONTRACT=0x_inft_contract_address_here

# TrustFolioMarketplace contract
NEXT_PUBLIC_MARKETPLACE_CONTRACT=0x_marketplace_contract_address_here
MARKETPLACE_CONTRACT=0x_marketplace_contract_address_here

# TrustFolioHiringEscrow contract
NEXT_PUBLIC_HIRING_ESCROW_CONTRACT=0x_hiring_escrow_address_here
HIRING_ESCROW_CONTRACT=0x_hiring_escrow_address_here

# Admin dashboard — wallet address that can view admin stats (optional, defaults to all)
NEXT_PUBLIC_ADMIN_ADDRESS=0x_your_admin_wallet_address

# ── Phase 4: Scale & Monetize ─────────────────────────────────────────────────
# Deploy all Phase 4 contracts:
#   npx hardhat run scripts/deploy-phase4.js --network 0g-testnet
# Addresses are auto-saved to deployments/phase4.json — paste them below:

# TRUST Token (ERC-20 + ERC20Votes, 100M supply)
NEXT_PUBLIC_TRUST_TOKEN_CONTRACT=0x_trust_token_address_here

# Staking contract (stake TRUST, earn 8% APY)
NEXT_PUBLIC_STAKING_CONTRACT=0x_staking_address_here

# RewardsDistributor (verify-to-earn TRUST rewards)
NEXT_PUBLIC_REWARDS_DISTRIBUTOR_CONTRACT=0x_rewards_distributor_address_here

# TrustGovernor (DAO governance via OpenZeppelin Governor)
NEXT_PUBLIC_TRUST_GOVERNOR_CONTRACT=0x_trust_governor_address_here

# TimeLock (2-day delay on governance execution)
NEXT_PUBLIC_TIMELOCK_CONTRACT=0x_timelock_address_here

# Treasury (DAO-controlled fee treasury)
NEXT_PUBLIC_TREASURY_CONTRACT=0x_treasury_address_here

# CrossChainVerifier (publish proofs for cross-chain verification)
NEXT_PUBLIC_CROSS_CHAIN_VERIFIER_CONTRACT=0x_cross_chain_verifier_address_here

# APIKeyRegistry (on-chain API key hash storage)
NEXT_PUBLIC_API_KEY_REGISTRY_CONTRACT=0x_api_key_registry_address_here
